    {
      "name": "Sync",
      "item": [
        {
          "name": "Upload Scan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Has server_scan_id', () => pm.expect(json).to.have.property('server_scan_id'));",
                  "pm.test('Has network_id', () => pm.expect(json).to.have.property('network_id'));",
                  "pm.test('accepted is true', () => pm.expect(json.accepted).to.be.true);",
                  "if (json.server_scan_id) pm.collectionVariables.set('scan_id', json.server_scan_id);",
                  "if (json.network_id) pm.collectionVariables.set('network_id', json.network_id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate random UUID for client_scan_id",
                  "const uuid = () => 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {",
                  "  const r = Math.random() * 16 | 0;",
                  "  return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);",
                  "});",
                  "const clientScanId = uuid();",
                  "pm.collectionVariables.set('client_scan_id', clientScanId);",
                  "",
                  "const canonical = {",
                  "  client_scan_id: clientScanId,",
                  "  network: {",
                  "    ssid: 'FreeWiFi',",
                  "    bssid: 'AA:BB:CC:DD:EE:FF',",
                  "    channel: 6,",
                  "    encryption_type: 'OPEN',",
                  "    frequency_mhz: 2437,",
                  "    gps_latitude: 50.0647,",
                  "    gps_longitude: 19.945",
                  "  },",
                  "  safety_score: 67.9,",
                  "  scan_duration_sec: 120,",
                  "  scan_config: { modules: ['ALL'], duration: 120 },",
                  "  attacks: [{",
                  "    attack_type: 'ARP_SPOOFING',",
                  "    severity: 'HIGH',",
                  "    confidence: 0.87,",
                  "    detected_at: '2026-05-05T10:29:15Z',",
                  "    details: { attacker_mac: 'XX:XX:XX:XX:XX:XX', target_ip: '192.168.1.1' }",
                  "  }],",
                  "  device_hardware_id: 'rpi-serial-xxxx',",
                  "  firmware_version: '1.2.0',",
                  "  started_at: '2026-05-05T10:28:00Z',",
                  "  completed_at: '2026-05-05T10:30:00Z'",
                  "};",
                  "",
                  "// SHA-256 using inline require to avoid redeclaration",
                  "const hash = require('crypto-js').SHA256(JSON.stringify(canonical)).toString();",
                  "pm.collectionVariables.set('payload_hash', hash);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_scan_id\": \"{{client_scan_id}}\",\n  \"network\": {\n    \"ssid\": \"FreeWiFi\",\n    \"bssid\": \"AA:BB:CC:DD:EE:FF\",\n    \"channel\": 6,\n    \"encryption_type\": \"OPEN\",\n    \"frequency_mhz\": 2437,\n    \"gps_latitude\": 50.0647,\n    \"gps_longitude\": 19.945\n  },\n  \"safety_score\": 67.9,\n  \"scan_duration_sec\": 120,\n  \"scan_config\": {\n    \"modules\": [\n      \"ALL\"\n    ],\n    \"duration\": 120\n  },\n  \"attacks\": [\n    {\n      \"attack_type\": \"ARP_SPOOFING\",\n      \"severity\": \"HIGH\",\n      \"confidence\": 0.87,\n      \"detected_at\": \"2026-05-05T10:29:15Z\",\n      \"details\": {\n        \"attacker_mac\": \"XX:XX:XX:XX:XX:XX\",\n        \"target_ip\": \"192.168.1.1\"\n      }\n    }\n  ],\n  \"device_hardware_id\": \"rpi-serial-xxxx\",\n  \"firmware_version\": \"1.2.0\",\n  \"started_at\": \"2026-05-05T10:28:00Z\",\n  \"completed_at\": \"2026-05-05T10:30:00Z\",\n  \"payload_hash\": \"{{payload_hash}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/sync",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "sync"
              ]
            }
          },
          "response": []
        },
