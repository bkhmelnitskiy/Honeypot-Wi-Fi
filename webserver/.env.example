# Application
PORT=3000
NODE_ENV=development

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=honeypot
DB_PASSWORD=honeypot
DB_DATABASE=honeypot

# JWT
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=2592000

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Metrics
METRICS_API_KEY=CHANGE_ME_TO_RANDOM_TOKEN

# Database observability
DB_SLOW_QUERY_MS=500
